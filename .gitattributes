# Ative Git LFS antes de adicionar arquivos grandes:
# git lfs install
# git lfs track "dados/raw/**/*.csv"
# git lfs track "dados/raw/**/*.xlsx"
# git lfs track "figuras/**/*.png"
# git lfs track "figuras/**/*.svg"

dados/raw/**/*.csv filter=lfs diff=lfs merge=lfs -text
dados/raw/**/*.xlsx filter=lfs diff=lfs merge=lfs -text
figuras/**/*.png filter=lfs diff=lfs merge=lfs -text
figuras/**/*.svg filter=lfs diff=lfs merge=lfs -text
